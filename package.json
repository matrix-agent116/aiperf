{
  "name": "gh-triage-agent",
  "version": "0.1.0",
  "description": "配置驱动多仓库轮询 + 人在环路的 GitHub Issue/PR 判定 Agent（Claude Agent SDK + Telegram）",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc",
    "start": "node src/index.ts",
    "poll-once": "node src/index.ts --once",
    "dev": "node --watch src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@octokit/rest": "^21.0.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.30.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
