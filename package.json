{
  "name": "gh-triage-agent",
  "version": "0.2.0",
  "description": "配置驱动多仓库轮询 + 人在环路的 GitHub Issue/PR 判定 Agent（Claude Agent SDK + 桌面 App）",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "app": "npm start --workspace gh-triage-desktop",
    "headless": "node packages/core/src/headless.ts",
    "poll-once": "node packages/core/src/headless.ts --once",
    "dev": "node --watch packages/core/src/headless.ts",
    "typecheck": "tsc -p packages/core"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
