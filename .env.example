# Claude Agent SDK 认证（判定用）—— 二选一：
#
# 方式 A（推荐，用 Claude Code 订阅）：先在终端跑 `claude setup-token` 生成长期
# OAuth token，把它填到这里。不要再设置 ANTHROPIC_API_KEY（会覆盖它）。
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# 方式 B（用 API key 计费）：注释掉上面那行，改用
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT / App token —— 需对被监控仓库有写权限（发评论/关闭/审批）
GITHUB_TOKEN=ghp_...

# Telegram Bot Token（找 @BotFather 创建）
TELEGRAM_BOT_TOKEN=123456:ABC-...

# 可选：配置文件路径（默认 ./config.yaml）
# CONFIG_PATH=./config.yaml

# 可选：sqlite 数据文件路径（默认 ./data/state.db）
# DB_PATH=./data/state.db
